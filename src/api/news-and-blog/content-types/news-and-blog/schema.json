{
  "kind": "collectionType",
  "collectionName": "news_and_blogs",
  "info": {
    "singularName": "news-and-blog",
    "pluralName": "news-and-blogs",
    "displayName": "News And Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "published_on": {
      "type": "date",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "required": true,
      "target": "api::publication-category.publication-category"
    },
    "meta_title": {
      "type": "string"
    },
    "meta_description": {
      "type": "text"
    },
    "meta_keywords": {
      "type": "string"
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "media": {
      "type": "component",
      "component": "utils.s-ingle-media-without-t-ype",
      "repeatable": false,
      "required": true
    }
  }
}
